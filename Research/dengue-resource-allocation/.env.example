# Dengue Backend Environment Variables
# Copy this to .env and update with your actual values

# API Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Configuration (adjust for production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174"]

# Routing Service Configuration
# Set to 'mock' for development/demo, 'google_maps' for production
ROUTING_PROVIDER=mock

# Google Maps Integration (Required when ROUTING_PROVIDER=google_maps)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Required APIs: Directions API, Distance Matrix API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Google Maps Configuration
GOOGLE_MAPS_REGION=LK
GOOGLE_MAPS_LANGUAGE=en

# Database Configuration (if using a database instead of JSON storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/dengue_db
# DATABASE_URL=sqlite:///./dengue.db

# Redis Configuration (for caching route calculations)
# REDIS_URL=redis://localhost:6379/0

# Pilot Study Configuration
PILOT_MODE=True

# ML Models Configuration (paths are relative to project root)
MODELS_DIR=./models
DATA_DIR=./data

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=detailed